# ============================================================
# PRAHO Production Environment Configuration
# ============================================================
# Copy to .env.prod, fill in values, then deploy:
#   cp .env.example.prod .env.prod
#   # Edit .env.prod with your values
#   make deploy-prod
#
# Legend:
#   [REQUIRED]       — PRAHO won't start without this
#   [RECOMMENDED]    — Core feature disabled without this
#   [OPTIONAL]       — Has a sensible default, override only if needed
#
# Generate secrets:
#   openssl rand -base64 50   (SECRET_KEY)
#   openssl rand -base64 32   (DB_PASSWORD, HMAC_SECRET)
#   python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
# ============================================================

# --- Server (used by Ansible, not by Django) -----------------
PRAHO_SERVER_IP=                        # [REQUIRED] Server public IP
PRAHO_SSH_USER=root                     # [OPTIONAL] SSH user for Ansible
PRAHO_SSH_KEY=~/.ssh/id_ed25519         # [OPTIONAL] SSH key path

# --- Domains -------------------------------------------------
PORTAL_DOMAIN=                          # [REQUIRED] e.g. portal.pragmatichost.com
PLATFORM_DOMAIN=                        # [REQUIRED] e.g. platform.pragmatichost.com
ACME_EMAIL=                             # [REQUIRED] Let's Encrypt notification email
ALLOWED_HOSTS=                          # [REQUIRED] Set by Ansible: portal,platform,localhost,127.0.0.1

# --- Secrets -------------------------------------------------
SECRET_KEY=                             # [REQUIRED] openssl rand -base64 50
DJANGO_SECRET_KEY=                      # [REQUIRED] Same value as SECRET_KEY (Django reads this)
DB_PASSWORD=                            # [REQUIRED] openssl rand -base64 32
HMAC_SECRET=                            # [REQUIRED] openssl rand -base64 32 — portal↔platform auth
PLATFORM_API_SECRET=                    # [REQUIRED] Same value as HMAC_SECRET

# --- Database ------------------------------------------------
DB_NAME=praho                           # [OPTIONAL] PostgreSQL database name
DB_USER=praho                           # [OPTIONAL] PostgreSQL user
DB_HOST=localhost                       # [OPTIONAL] PostgreSQL host
DB_PORT=5432                            # [OPTIONAL] PostgreSQL port
DB_SSLMODE=require                      # [OPTIONAL] 'require' for remote DB, 'disable' for localhost

# --- Application ---------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.prod  # [OPTIONAL] Set by Ansible based on praho_env
DEBUG=false                             # [OPTIONAL] NEVER true in production

# --- Inter-Service Communication -----------------------------
PLATFORM_API_BASE_URL=http://localhost:8700/api  # [OPTIONAL] Native: localhost, Docker: container name
PLATFORM_API_ALLOW_INSECURE_HTTP=true   # [OPTIONAL] true for localhost inter-service (behind Caddy)

# --- Static & Media ------------------------------------------
STATIC_ROOT=/opt/praho/static           # [OPTIONAL] Set by Ansible
MEDIA_ROOT=/opt/praho/media             # [OPTIONAL] Set by Ansible

# --- Email ---------------------------------------------------
EMAIL_PROVIDER=smtp                     # [RECOMMENDED] smtp|amazon_ses|sendgrid|mailgun
EMAIL_HOST=                             # [RECOMMENDED] SMTP server (e.g. smtp.gmail.com)
EMAIL_PORT=587                          # [OPTIONAL] SMTP port
EMAIL_HOST_USER=                        # [RECOMMENDED] SMTP username
EMAIL_HOST_PASSWORD=                    # [RECOMMENDED] SMTP password
EMAIL_TIMEOUT=30                        # [OPTIONAL] SMTP timeout in seconds
DEFAULT_FROM_EMAIL=PRAHO Platform <noreply@pragmatichost.com>  # [OPTIONAL]
SERVER_EMAIL=server@pragmatichost.com   # [OPTIONAL] Error notification sender

# Email: AWS SES (if EMAIL_PROVIDER=amazon_ses)
# AWS_ACCESS_KEY_ID=                    # [RECOMMENDED:ses] AWS credentials
# AWS_SECRET_ACCESS_KEY=                # [RECOMMENDED:ses]
# AWS_SES_REGION=eu-west-1             # [OPTIONAL:ses]
# AWS_SES_CONFIGURATION_SET=           # [OPTIONAL:ses]

# Email: SendGrid (if EMAIL_PROVIDER=sendgrid)
# SENDGRID_API_KEY=                    # [RECOMMENDED:sendgrid]

# Email: Mailgun (if EMAIL_PROVIDER=mailgun)
# MAILGUN_API_KEY=                     # [RECOMMENDED:mailgun]
# MAILGUN_SENDER_DOMAIN=              # [RECOMMENDED:mailgun]
# MAILGUN_API_URL=https://api.eu.mailgun.net/v3  # [OPTIONAL:mailgun] EU region

# Email: Rate Limiting
EMAIL_MAX_PER_MINUTE=50                 # [OPTIONAL]
EMAIL_MAX_PER_HOUR=1000                 # [OPTIONAL]
EMAIL_MAX_PER_DAY=10000                 # [OPTIONAL]
EMAIL_BURST_SIZE=100                    # [OPTIONAL]
EMAIL_MAX_RETRIES=3                     # [OPTIONAL]
EMAIL_RETRY_DELAY=60                    # [OPTIONAL] seconds
EMAIL_WEBHOOK_SECRET=                   # [OPTIONAL] Webhook signature validation

# Email: Templates & Deliverability
EMAIL_TEMPLATE_CACHE_TIMEOUT=3600       # [OPTIONAL] seconds
EMAIL_TEMPLATE_STRICT_MODE=false        # [OPTIONAL]
EMAIL_SOFT_BOUNCE_THRESHOLD=3           # [OPTIONAL]

# --- Payments (Stripe) --------------------------------------
STRIPE_PUBLISHABLE_KEY=                 # [RECOMMENDED] From Stripe dashboard
STRIPE_SECRET_KEY=                      # [RECOMMENDED] From Stripe dashboard
STRIPE_WEBHOOK_SECRET=                  # [RECOMMENDED] From Stripe webhooks

# --- Romanian Compliance ------------------------------------
EFACTURA_API_URL=                       # [RECOMMENDED] https://api.anaf.ro/prod/FCTEL/rest
EFACTURA_API_KEY=                       # [RECOMMENDED] ANAF OAuth key

# Company information (appears on invoices)
COMPANY_NAME=                           # [RECOMMENDED] Legal company name
COMPANY_CUI=                            # [RECOMMENDED] Romanian tax ID (e.g. RO12345678)
COMPANY_ADDRESS=                        # [RECOMMENDED] Street address
COMPANY_CITY=                           # [RECOMMENDED] City
COMPANY_COUNTRY=România                 # [OPTIONAL]
COMPANY_EMAIL=                          # [OPTIONAL] Contact email
COMPANY_PHONE=                          # [OPTIONAL] Contact phone
COMPANY_WEBSITE=                        # [OPTIONAL]

# --- Encryption ----------------------------------------------
DJANGO_ENCRYPTION_KEY=                  # [RECOMMENDED] Fernet key — encrypts TOTP secrets for 2FA
CREDENTIAL_VAULT_MASTER_KEY=            # [RECOMMENDED] Fernet key — encrypts provider credentials
CREDENTIAL_VAULT_ENABLED=true           # [OPTIONAL]
CREDENTIAL_VAULT_DEFAULT_EXPIRY_DAYS=30 # [OPTIONAL]
CREDENTIAL_VAULT_MAX_AGE_DAYS=90        # [OPTIONAL]

# --- Monitoring & Logging ------------------------------------
SENTRY_DSN=                             # [OPTIONAL] Sentry error tracking DSN
LOG_LEVEL=INFO                          # [OPTIONAL] INFO for production
APP_VERSION=                            # [OPTIONAL] Shown in Sentry releases

# --- SIEM Integration ----------------------------------------
# Uncomment if using Splunk/QRadar/Elastic SIEM
# SIEM_ENABLED=false                   # [OPTIONAL] Enable SIEM log forwarding
# SIEM_FORMAT=json                     # [OPTIONAL] cef|leef|json|syslog
# SIEM_PROTOCOL=tcp                    # [OPTIONAL] tcp|udp|https|file
# SIEM_HOST=localhost                  # [OPTIONAL] SIEM collector host
# SIEM_PORT=514                        # [OPTIONAL] SIEM collector port

# --- Cache ---------------------------------------------------
# PRAHO uses database cache by default (no Redis required).
# Uncomment for Redis:
# REDIS_URL=redis://localhost:6379/0   # [OPTIONAL] Redis URL for caching
CACHE_VERSION=1                         # [OPTIONAL] Increment to invalidate all caches

# --- Performance Tuning --------------------------------------
HTTP_POOL_CONNECTIONS=10                # [OPTIONAL] Outbound HTTP pool
HTTP_POOL_MAXSIZE=20                    # [OPTIONAL]
HTTP_MAX_RETRIES=3                      # [OPTIONAL]
HTTP_TIMEOUT_CONNECT=10.0              # [OPTIONAL] seconds
HTTP_TIMEOUT_READ=30.0                 # [OPTIONAL] seconds

# --- Backup --------------------------------------------------
# BACKUP_S3_BUCKET=                    # [OPTIONAL] S3 bucket for off-site backups
# BACKUP_ENCRYPTION_KEY=               # [OPTIONAL] Encrypt backups at rest

# --- Localization --------------------------------------------
LANGUAGE_CODE=ro-RO                     # [OPTIONAL]
TIME_ZONE=Europe/Bucharest              # [OPTIONAL]

# --- Superuser (first deploy only) ---------------------------
# Created by setup_initial_data if no superuser exists
# DJANGO_SUPERUSER_EMAIL=admin@pragmatichost.com  # [OPTIONAL]
# DJANGO_SUPERUSER_PASSWORD=                       # [OPTIONAL]
