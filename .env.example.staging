# ============================================================
# PRAHO Staging Environment Configuration
# ============================================================
# Staging uses config.settings.staging which differs from prod:
#
#   EMAIL:      Console backend (no real emails sent)
#   e-FACTURA:  Test mode (ANAF sandbox, not production)
#   HSTS:       1 hour (not 1 year) — allows HTTP rollback
#   SESSIONS:   2 hours, no browser-close expiry (lenient for testing)
#   DB SSL:     'prefer' not 'require' — staging DB may lack SSL
#   RETENTION:  30 days (not 7 years) — don't keep years of test data
#   LOGGING:    DEBUG level, smaller log rotation
#
# Because of these staging overrides, the following are NOT required:
#   EMAIL_HOST, EMAIL_HOST_USER, EMAIL_HOST_PASSWORD (console backend)
#   EFACTURA_API_KEY (test mode uses mock)
#   STRIPE_* keys (can use Stripe test keys or skip entirely)
#
# Copy to .env.staging, fill in values, then deploy:
#   cp .env.example.staging .env.staging
#   # Edit .env.staging with your values
#   make deploy-staging
#
# Legend:
#   [REQUIRED]       — PRAHO won't start without this
#   [RECOMMENDED]    — Core feature disabled without this
#   [OPTIONAL]       — Has a sensible default, override only if needed
#   [OPTIONAL:staging] — Not required in staging (overridden by staging settings)
# ============================================================

# --- Server (used by Ansible, not by Django) -----------------
PRAHO_SERVER_IP=                        # [REQUIRED] Server public IP
PRAHO_SSH_USER=root                     # [OPTIONAL] SSH user for Ansible
PRAHO_SSH_KEY=~/.ssh/id_ed25519         # [OPTIONAL] SSH key path

# --- Deployment (used by Ansible, not by Django) ---------------
DEPLOY_METHOD=git                       # [OPTIONAL] git (default) or rsync (local working tree)
DEPLOY_BRANCH=staging                   # [OPTIONAL] Git branch when DEPLOY_METHOD=git (default: staging)

# --- Domains -------------------------------------------------
PORTAL_DOMAIN=                          # [REQUIRED] e.g. staging.portal.pragmatichost.com
PLATFORM_DOMAIN=                        # [REQUIRED] e.g. staging.platform.pragmatichost.com
ACME_EMAIL=                             # [REQUIRED] Let's Encrypt notification email
ALLOWED_HOSTS=                          # [REQUIRED] Set by Ansible: portal,platform,localhost,127.0.0.1

# --- Secrets -------------------------------------------------
SECRET_KEY=                             # [REQUIRED] openssl rand -base64 50
DJANGO_SECRET_KEY=                      # [REQUIRED] Same value as SECRET_KEY
DB_PASSWORD=                            # [REQUIRED] openssl rand -base64 32
HMAC_SECRET=                            # [REQUIRED] openssl rand -base64 32 — portal↔platform auth
PLATFORM_API_SECRET=                    # [REQUIRED] Same value as HMAC_SECRET
PLATFORM_TO_PORTAL_WEBHOOK_SECRET=      # [REQUIRED] python -c "import secrets; print(secrets.token_urlsafe(32))" — platform→portal webhook auth

# --- Database ------------------------------------------------
DB_NAME=praho                           # [OPTIONAL]
DB_USER=praho                           # [OPTIONAL]
DB_HOST=localhost                       # [OPTIONAL]
DB_PORT=5432                            # [OPTIONAL]
DB_SSLMODE=disable                      # [OPTIONAL] 'disable' OK for localhost staging

# --- Application ---------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.staging  # ← This is the key difference from prod
DEBUG=false                             # [OPTIONAL]

# --- Inter-Service Communication -----------------------------
PLATFORM_API_BASE_URL=http://localhost:8700/api  # [OPTIONAL]
PLATFORM_API_ALLOW_INSECURE_HTTP=true   # [OPTIONAL]

# --- Static & Media ------------------------------------------
STATIC_ROOT=/opt/praho/static           # [OPTIONAL]
MEDIA_ROOT=/opt/praho/media             # [OPTIONAL]

# --- Email (console backend in staging — no real emails) -----
# Staging uses django.core.mail.backends.console.EmailBackend
# These are optional — emails go to journalctl instead of SMTP:
# EMAIL_PROVIDER=smtp                  # [OPTIONAL:staging] Not needed
# EMAIL_HOST=                          # [OPTIONAL:staging] Not needed
# EMAIL_HOST_USER=                     # [OPTIONAL:staging] Not needed
# EMAIL_HOST_PASSWORD=                 # [OPTIONAL:staging] Not needed
DEFAULT_FROM_EMAIL=staging-noreply@pragmatichost.com  # [OPTIONAL]

# --- Payments (Stripe) — test keys OK -----------------------
# STRIPE_PUBLISHABLE_KEY=pk_test_...  # [OPTIONAL:staging] Stripe test key
# STRIPE_SECRET_KEY=sk_test_...       # [OPTIONAL:staging] Stripe test key
# STRIPE_WEBHOOK_SECRET=whsec_...     # [OPTIONAL:staging]

# --- Romanian Compliance (test mode in staging) --------------
# e-Factura runs in test mode — no real ANAF submissions
# EFACTURA_API_URL=                   # [OPTIONAL:staging] Test mode doesn't call ANAF
# EFACTURA_API_KEY=                   # [OPTIONAL:staging] Not needed in test mode

# Company information (test data OK)
COMPANY_NAME="PragmaticHost SRL (STAGING)"  # [OPTIONAL]
COMPANY_CUI=RO12345678                 # [OPTIONAL] Test CUI
COMPANY_ADDRESS="Str. Exemplu Nr. 1"   # [OPTIONAL]
COMPANY_CITY=București                  # [OPTIONAL]
COMPANY_COUNTRY=România                 # [OPTIONAL]

# --- Encryption ----------------------------------------------
DJANGO_ENCRYPTION_KEY=                  # [RECOMMENDED] AES-256-GCM key — needed for 2FA testing
CREDENTIAL_VAULT_MASTER_KEY=            # [RECOMMENDED] AES-256-GCM key — needed for provider creds
CREDENTIAL_VAULT_ENABLED=true           # [OPTIONAL]

# --- Monitoring & Logging ------------------------------------
# SENTRY_DSN=                          # [OPTIONAL] Separate staging Sentry project
LOG_LEVEL=DEBUG                         # [OPTIONAL] More verbose for staging

# --- Cache ---------------------------------------------------
CACHE_VERSION=1                         # [OPTIONAL]

# --- Localization --------------------------------------------
LANGUAGE_CODE=ro-RO                     # [OPTIONAL]
TIME_ZONE=Europe/Bucharest              # [OPTIONAL]
