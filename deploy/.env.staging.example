# PRAHO Staging Deployment Environment
# Copy to deploy/.env.staging and fill in values:
#   cp deploy/.env.staging.example deploy/.env.staging
#
# Deploy with:
#   source deploy/.env.staging && make deploy-staging-native

# Server
export PRAHO_STAGING_IP=<your-server-ip>
export PRAHO_SSH_USER=root
export PRAHO_SSH_KEY=~/.ssh/id_ed25519

# Domains (must resolve to PRAHO_STAGING_IP via DNS A records)
export PRAHO_PORTAL_DOMAIN=staging.portal.example.com
export PRAHO_PLATFORM_DOMAIN=staging.platform.example.com

# Secrets (generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
export PRAHO_DB_PASSWORD=
export PRAHO_SECRET_KEY=
export PRAHO_HMAC_SECRET=

# ACME/TLS
export PRAHO_ACME_EMAIL=admin@example.com
