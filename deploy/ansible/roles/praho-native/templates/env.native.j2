# PRAHO Environment Configuration (Native)
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT - managed by Ansible

# Domain
PORTAL_DOMAIN={{ portal_domain }}
PLATFORM_DOMAIN={{ platform_domain }}
ACME_EMAIL={{ acme_email }}
ALLOWED_HOSTS={{ portal_domain }},{{ platform_domain }},localhost,127.0.0.1

# Database (localhost - native PostgreSQL)
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@localhost:{{ db_port }}/{{ db_name }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_HOST=localhost
DB_PORT={{ db_port }}
DB_SSLMODE=disable
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

# Application
DJANGO_SECRET_KEY={{ secret_key }}
SECRET_KEY={{ secret_key }}
DEBUG={{ debug | lower }}
DJANGO_SETTINGS_MODULE={{ django_settings_module }}

# Service URLs (localhost - native services)
PLATFORM_API_BASE_URL=http://localhost:{{ platform_port }}/api
PLATFORM_API_ALLOW_INSECURE_HTTP=true

# Static / Media
STATIC_ROOT={{ project_root }}/static
MEDIA_ROOT={{ project_root }}/media

# Version
VERSION={{ praho_version | default('latest') }}

# Logging
LOG_LEVEL={{ log_level | default('INFO') }}
SENTRY_ENVIRONMENT={{ sentry_environment | default(environment) }}
{% if sentry_dsn is defined and sentry_dsn %}
SENTRY_DSN={{ sentry_dsn }}
{% endif %}

# Security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Localization
LANGUAGE_CODE=ro-RO
TIME_ZONE=Europe/Bucharest

# HMAC (portal ↔ platform)
{% if hmac_secret is defined and hmac_secret %}
HMAC_SECRET={{ hmac_secret }}
PLATFORM_API_SECRET={{ hmac_secret }}
{% endif %}

# Superuser (only used on first deploy — setup_initial_data creates if no superuser exists)
{% if superuser_email is defined and superuser_email %}
DJANGO_SUPERUSER_EMAIL={{ superuser_email }}
DJANGO_SUPERUSER_PASSWORD={{ superuser_password }}
{% endif %}
