# PRAHO Caddy Configuration (Native) — Two-Domain Architecture
# Generated by Ansible - DO NOT EDIT
#
# Portal:   {{ portal_domain }} (public)
# Platform: {{ platform_domain }} (restricted)

# ---------------------------------------------------------------------------
# 1. Portal — public-facing customer service
# ---------------------------------------------------------------------------
{{ portal_domain }} {
    tls {{ acme_email }}

    # Security headers
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    encode gzip zstd

    # Portal static files
    handle_path /static/* {
        root * {{ project_root }}/portal-static
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Portal health check
    handle /health/* {
        reverse_proxy localhost:{{ portal_port }}
    }

    # All other traffic → Portal
    handle {
        reverse_proxy localhost:{{ portal_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    log {
        output file /var/log/caddy/portal-access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}

# ---------------------------------------------------------------------------
# 2. Platform — staff/admin service (IP-restricted when configured)
# ---------------------------------------------------------------------------
{{ platform_domain }} {
    tls {{ acme_email }}

{% if platform_allowed_ips | default([]) | length > 0 %}
    @allowed remote_ip {{ platform_allowed_ips | join(' ') }}
    handle @allowed {
        # Security headers
        header {
            X-Frame-Options "DENY"
            X-Content-Type-Options "nosniff"
            X-XSS-Protection "1; mode=block"
            Referrer-Policy "strict-origin-when-cross-origin"
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            -Server
        }

        encode gzip zstd

        # Platform static files
        handle_path /static/* {
            root * {{ project_root }}/static
            file_server
            header Cache-Control "public, max-age=31536000, immutable"
        }

        # Media files
        handle_path /media/* {
            root * {{ project_root }}/media
            file_server
            header Cache-Control "public, max-age=86400"
        }

        # All Platform routes
        reverse_proxy localhost:{{ platform_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    # Reject all other IPs
    respond "Access denied" 403
{% else %}
    # No IP restriction configured — unrestricted access
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    encode gzip zstd

    # Platform static files
    handle_path /static/* {
        root * {{ project_root }}/static
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    # Media files
    handle_path /media/* {
        root * {{ project_root }}/media
        file_server
        header Cache-Control "public, max-age=86400"
    }

    # Health check (no restriction)
    handle /api/users/health/* {
        reverse_proxy localhost:{{ platform_port }}
    }

    # All Platform routes
    handle {
        reverse_proxy localhost:{{ platform_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
{% endif %}

    log {
        output file /var/log/caddy/platform-access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}

# ---------------------------------------------------------------------------
# 3. Bare IP — redirect to portal domain
# ---------------------------------------------------------------------------
http://{{ ansible_default_ipv4.address | default('0.0.0.0') }} {
    redir https://{{ portal_domain }}{uri} permanent
}
