# PRAHO Environment Configuration (Docker)
# Generated by Ansible on {{ ansible_date_time.iso8601 }}
# DO NOT EDIT - managed by Ansible

# Domain
PORTAL_DOMAIN={{ portal_domain }}
PLATFORM_DOMAIN={{ platform_domain }}
ACME_EMAIL={{ acme_email }}
ALLOWED_HOSTS={{ portal_domain }},{{ platform_domain }},localhost,127.0.0.1

# Database (Docker service name)
DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@{{ 'db' if deploy_database else db_host }}:{{ db_port }}/{{ db_name }}
DB_NAME={{ db_name }}
DB_USER={{ db_user }}
DB_PASSWORD={{ db_password }}
DB_HOST={{ 'db' if deploy_database else db_host }}
DB_PORT={{ db_port }}
DB_SSLMODE={{ db_sslmode | default('disable') }}
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True

# Application
DJANGO_SECRET_KEY={{ secret_key }}
DEBUG={{ debug | lower }}
DJANGO_SETTINGS_MODULE=config.settings.prod

# Service URLs (Docker internal network)
{% if deploy_platform %}
PLATFORM_API_BASE_URL=http://platform:{{ platform_port }}/api
{% else %}
PLATFORM_API_BASE_URL={{ platform_api_url | default('http://platform:8700/api') }}
{% endif %}
PLATFORM_API_ALLOW_INSECURE_HTTP={{ platform_api_allow_insecure_http | default('true') }}

# HMAC (portal ↔ platform)
{% if hmac_secret is defined and hmac_secret %}
HMAC_SECRET={{ hmac_secret }}
PLATFORM_API_SECRET={{ hmac_secret }}
{% endif %}

# Static / Media
STATIC_ROOT=/app/staticfiles
MEDIA_ROOT=/app/media

# Version
VERSION={{ praho_version | default('latest') }}

# Logging
LOG_LEVEL={{ log_level | default('INFO') }}
SENTRY_ENVIRONMENT={{ sentry_environment | default(environment) }}
{% if sentry_dsn is defined and sentry_dsn %}
SENTRY_DSN={{ sentry_dsn }}
{% endif %}

# Security
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Localization
LANGUAGE_CODE=ro-RO
TIME_ZONE=Europe/Bucharest

# Superuser (only used on first deploy — setup_initial_data creates if no superuser exists)
{% if superuser_email is defined and superuser_email %}
DJANGO_SUPERUSER_EMAIL={{ superuser_email }}
DJANGO_SUPERUSER_PASSWORD={{ superuser_password }}
{% endif %}
