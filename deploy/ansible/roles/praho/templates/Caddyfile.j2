# PRAHO Caddy Configuration (Docker) — Two-Domain Architecture
# Generated by Ansible
#
# Portal:   {{ portal_domain }} (public)
# Platform: {{ platform_domain }} (restricted)

# ---------------------------------------------------------------------------
# 1. Portal — public-facing customer service
# ---------------------------------------------------------------------------
{% if deploy_portal %}
{{ portal_domain }} {
    tls {{ acme_email }}

    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    encode gzip zstd

    handle_path /static/* {
        root * /srv/portal-static
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    handle /health/* {
        reverse_proxy portal:{{ portal_port }}
    }

    handle {
        reverse_proxy portal:{{ portal_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    log {
        output file /data/portal-access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}
{% endif %}

# ---------------------------------------------------------------------------
# 2. Platform — staff/admin service (IP-restricted when configured)
# ---------------------------------------------------------------------------
{% if deploy_platform %}
{{ platform_domain }} {
    tls {{ acme_email }}

{% if platform_allowed_ips | default([]) | length > 0 %}
    @allowed remote_ip {{ platform_allowed_ips | join(' ') }}
    handle @allowed {
        header {
            X-Frame-Options "DENY"
            X-Content-Type-Options "nosniff"
            Permissions-Policy "camera=(), microphone=(), geolocation=()"
            Referrer-Policy "strict-origin-when-cross-origin"
            Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
            -Server
        }

        encode gzip zstd

        handle_path /static/* {
            root * /srv/static
            file_server
            header Cache-Control "public, max-age=31536000, immutable"
        }

        handle_path /media/* {
            root * /srv/media
            file_server
            header Cache-Control "public, max-age=86400"
        }

        reverse_proxy platform:{{ platform_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    respond "Access denied" 403
{% else %}
    header {
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Referrer-Policy "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    encode gzip zstd

    handle_path /static/* {
        root * /srv/static
        file_server
        header Cache-Control "public, max-age=31536000, immutable"
    }

    handle_path /media/* {
        root * /srv/media
        file_server
        header Cache-Control "public, max-age=86400"
    }

    handle /api/users/health/* {
        reverse_proxy platform:{{ platform_port }}
    }

    handle {
        reverse_proxy platform:{{ platform_port }} {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }
{% endif %}

    log {
        output file /data/platform-access.log {
            roll_size 100mb
            roll_keep 5
        }
    }
}
{% endif %}

# ---------------------------------------------------------------------------
# 3. Bare IP — redirect to portal domain
# ---------------------------------------------------------------------------
http://{{ ansible_default_ipv4.address | default('0.0.0.0') }} {
    redir https://{{ portal_domain }}{uri} permanent
}
