# PRAHO Deployment Secrets (Minimum)
# ─────────────────────────────────────────────────────────────────────
# This file contains ONLY the secrets and server info needed to run
# ansible-playbook. All other Django settings are configured in
# config/settings/{staging,prod}.py and group_vars/all.yml.
#
# NOT the same as .env.example in the project root (that's for local dev).
# After deployment, add optional integrations (email, Stripe, Sentry) to
# /opt/praho/env on the server. See docs/deployment/DEPLOYMENT.md.
#
# Copy for each deployment target:
#   cp .env.deploy.example .env.staging   # fill in staging values
#   cp .env.deploy.example .env.prod      # fill in prod values
#
# Usage:
#   source .env.staging
#   ansible-playbook -i inventory/native-single-server.yml \
#     playbooks/native-single-server.yml -e praho_env=staging -v
#
# Generate secrets:
#   openssl rand -base64 32   (DB_PASSWORD, HMAC_SECRET)
#   openssl rand -base64 50   (SECRET_KEY)
# ─────────────────────────────────────────────────────────────────────

# Server
export PRAHO_SERVER_IP=
export PRAHO_SSH_USER=root
export PRAHO_SSH_KEY=~/.ssh/id_ed25519

# Domains (both must resolve to PRAHO_SERVER_IP via DNS A records BEFORE deploying)
export PRAHO_PORTAL_DOMAIN=
export PRAHO_PLATFORM_DOMAIN=

# Secrets
export PRAHO_DB_PASSWORD=
export PRAHO_SECRET_KEY=
export PRAHO_HMAC_SECRET=

# ACME/TLS (Let's Encrypt notification email)
export PRAHO_ACME_EMAIL=
