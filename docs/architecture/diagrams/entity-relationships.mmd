%% PRAHO Platform - Database Entity Relationship Diagram
%% Updated: 2026-03-11
%% Entities use db_table values (matches SQL \dt output) — see ADR-0023 for full catalog
%% For db_table naming convention see: docs/ADRs/ADR-0023-database-structure.md
%% Monetary values stored as INTEGER in cents (subtotal_cents, tax_cents, total_cents)
%% PKs: UUID for all business-facing models; auto-increment for log/junction tables

erDiagram
    %% =========================================================================
    %% AUTHENTICATION & IDENTITY
    %% =========================================================================

    users {
        uuid id PK
        string email UK "Email-based auth (no username)"
        string staff_role "admin|support|billing|manager"
        bool two_factor_enabled
        datetime created_at
    }

    user_profiles {
        uuid id PK
        uuid user_id FK
        string preferred_language "ro|en"
        string timezone "Europe/Bucharest"
    }

    user_customer_memberships {
        uuid id PK
        uuid user_id FK
        uuid customer_id FK
        string role "owner|billing|tech|viewer"
        bool is_primary
    }

    %% =========================================================================
    %% BUSINESS ENTITIES
    %% =========================================================================

    customers {
        uuid id PK
        string name
        string customer_type "individual|company|pfa|ngo"
        string status "active|inactive|suspended|prospect"
        string company_name
        string primary_email
        datetime deleted_at "Soft delete"
    }

    customer_tax_profiles {
        uuid id PK
        uuid customer_id FK
        string vat_number
        bool is_vat_payer
        bool reverse_charge_eligible
    }

    customer_billing_profiles {
        uuid id PK
        uuid customer_id FK
        string default_currency
        string payment_terms
    }

    %% =========================================================================
    %% PRODUCT CATALOG
    %% =========================================================================

    products {
        uuid id PK
        string slug UK
        string name
        string product_type "shared_hosting|vps|domain|ssl|..."
        bool is_active
        uuid default_service_plan_id FK
    }

    product_prices {
        uuid id PK
        uuid product_id FK
        int currency_id FK
        bigint monthly_price_cents
        bigint setup_cents
        decimal semiannual_discount_percent
        decimal annual_discount_percent
    }

    %% =========================================================================
    %% ORDERS
    %% =========================================================================

    orders {
        uuid id PK
        string order_number UK
        uuid customer_id FK
        string status "draft|pending|confirmed|processing|completed|..."
        int currency_id FK
        bigint subtotal_cents
        bigint tax_cents
        bigint total_cents
        datetime created_at
    }

    order_items {
        uuid id PK
        uuid order_id FK
        uuid product_id FK
        int quantity
        bigint unit_price_cents
        bigint tax_cents
        bigint line_total_cents
        string provisioning_status
        uuid service_id FK "Optional - after provisioning"
    }

    %% =========================================================================
    %% BILLING & INVOICING
    %% =========================================================================

    billing_invoices {
        uuid id PK
        uuid customer_id FK
        string number UK "INV-000001 sequential"
        string status "draft|issued|paid|overdue|void|refunded"
        bigint subtotal_cents
        bigint tax_cents
        bigint total_cents
        uuid converted_from_proforma_id FK "Optional"
        datetime locked_at "Immutable once issued"
    }

    billing_invoice_lines {
        uuid id PK
        uuid invoice_id FK
        string description
        bigint amount_cents
        bigint tax_cents
    }

    billing_proforma_invoices {
        uuid id PK
        uuid customer_id FK
        string number UK "PRO-000001"
        string status
        bigint total_cents
    }

    billing_subscriptions {
        uuid id PK
        uuid customer_id FK
        uuid product_id FK
        string subscription_number UK
        string status "trialing|active|past_due|cancelled|..."
        string billing_cycle "monthly|quarterly|yearly"
        bigint amount_cents
    }

    %% =========================================================================
    %% HOSTING & PROVISIONING
    %% =========================================================================

    provisioning_service_plans {
        uuid id PK
        string name
        string plan_type "shared_hosting|vps|dedicated|..."
        decimal price_monthly
        int disk_space_gb
        int bandwidth_gb
    }

    provisioning_servers {
        uuid id PK
        string hostname UK
        string server_type "shared|vps_host|dedicated|cloud"
        string status "active|maintenance|offline"
        string primary_ip
    }

    provisioning_services {
        uuid id PK
        uuid customer_id FK
        uuid service_plan_id FK
        uuid server_id FK
        string service_name
        string username UK
        string status "pending|provisioning|active|suspended|terminated"
        string billing_cycle
    }

    %% =========================================================================
    %% DOMAINS
    %% =========================================================================

    domains {
        uuid id PK
        string name UK "example.com"
        uuid customer_id FK
        int tld_id FK
        int registrar_id FK
        string status "pending|active|expired|transfer_in|..."
        datetime expires_at
        bool auto_renew
    }

    domain_tlds {
        int id PK
        string extension UK "com|ro|eu|..."
        bigint registration_price_cents
        bigint renewal_price_cents
    }

    domain_registrars {
        int id PK
        string name UK
        string status "active|suspended|disabled"
        string api_endpoint
    }

    %% =========================================================================
    %% SUPPORT
    %% =========================================================================

    tickets {
        uuid id PK
        string ticket_number UK "TK2026-XXXXXXXX"
        uuid customer_id FK
        string status "open|in_progress|waiting_on_customer|closed"
        string priority "low|normal|high|urgent|critical"
        uuid assigned_to_id FK
    }

    ticket_comments {
        uuid id PK
        uuid ticket_id FK
        uuid author_id FK
        string comment_type "customer|support|internal|system"
        text content
    }

    ticket_attachments {
        uuid id PK
        uuid ticket_id FK
        uuid comment_id FK
        string filename
        int file_size
    }

    %% =========================================================================
    %% AUDIT (cross-cutting)
    %% =========================================================================

    audit_events {
        uuid id PK
        string category "authentication|security_event|..."
        string severity "low|medium|high|critical"
        int content_type_id FK "GenericFK to any model"
        string object_id
        datetime created_at "Append-only immutable"
    }

    %% =========================================================================
    %% RELATIONSHIPS
    %% =========================================================================

    users ||--o| user_profiles : "has"
    users ||--o{ user_customer_memberships : "holds"
    customers ||--o{ user_customer_memberships : "grants"
    customers ||--|| customer_tax_profiles : "has"
    customers ||--|| customer_billing_profiles : "has"

    customers ||--o{ orders : "places"
    customers ||--o{ billing_invoices : "receives"
    customers ||--o{ billing_proforma_invoices : "receives"
    customers ||--o{ billing_subscriptions : "subscribes"
    customers ||--o{ provisioning_services : "owns"
    customers ||--o{ domains : "registers"
    customers ||--o{ tickets : "opens"

    orders ||--o{ order_items : "contains"
    order_items }o--|| products : "references"
    order_items }o--o| provisioning_services : "provisions"

    products ||--o{ product_prices : "priced as"
    products }o--o| provisioning_service_plans : "maps to"
    billing_subscriptions }o--|| products : "subscribes to"

    billing_invoices ||--o{ billing_invoice_lines : "itemized as"
    billing_proforma_invoices ||--o{ billing_invoices : "converts to"

    domains }o--|| domain_tlds : "under"
    domains }o--|| domain_registrars : "managed by"

    provisioning_services }o--|| provisioning_service_plans : "based on"
    provisioning_services }o--o| provisioning_servers : "hosted on"

    tickets ||--o{ ticket_comments : "has"
    ticket_comments ||--o{ ticket_attachments : "attaches"
